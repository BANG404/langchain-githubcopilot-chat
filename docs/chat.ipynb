    "    },\n",
    ")\n",
    "response.raise_for_status()\n",
    "\n",
    "models = response.json()\n",
    "# Print id, name and rate_limit_tier for each model\n",
    "for m in models:\n",
    "    print(f\"{m['id']:<45} {m['name']:<35} tier={m.get('rate_limit_tier', 'n/a')}\")"
