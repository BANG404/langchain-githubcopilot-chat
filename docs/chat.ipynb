    "    response_metadata={'finish_reason': 'stop', 'usage': {'prompt_tokens': 28, 'completion_tokens': 8, 'total_tokens': 36}},\n",
    "    id='run-...',\n",
    "    usage_metadata={'input_tokens': 28, 'output_tokens': 8, 'total_tokens': 36}\n",
    ")\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d86145b3-bfef-46e8-b227-4dda5c9c2705",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(ai_msg.content)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "output-content",
   "metadata": {},
